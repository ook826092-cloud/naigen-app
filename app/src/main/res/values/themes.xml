<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      AppCompat 兼容主题。
      AppCompatActivity 必须用 Theme.AppCompat 系列主题，否则启动直接崩。
      这里继承 AppTheme，再补 AppCompat 必需的属性。
    -->
    <style name="Theme.NaiGen" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">@color/bg_primary_light</item>
        <item name="android:navigationBarColor">@color/bg_primary_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/bg_primary_light</item>
        <item name="android:windowIsTranslucent">false</item>

        <!-- AppCompat 必需 -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/bg_primary_light</item>
        <item name="colorAccent">@color/accent_blue</item>
    </style>
</resources>
