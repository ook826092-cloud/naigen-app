<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 暗色模式：AppCompat 兼容主题 -->
    <style name="Theme.NaiGen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@color/bg_primary_dark</item>
        <item name="android:navigationBarColor">@color/bg_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_primary_dark</item>
        <item name="android:windowIsTranslucent">false</item>

        <!-- AppCompat 必需 -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/bg_primary_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
    </style>
</resources>
